#   ssh -i "C:\Users\PraveenBhaskarani\Downloads\RSA.pem" \
#       -L 5433:agentic-erp-pgvector.cwb0sigyk8na.us-east-1.rds.amazonaws.com:5432 \
#       ec2-user@98.92.220.36 -N
DB_HOST=localhost
DB_PORT=5433
DB_NAME=agentdb
DB_USER=pgadmin
DB_PASSWORD=Agenticai1
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── AWS ───────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=241030170015
AWS_ACCESS_KEY_ID=AKIATQHUEQWPWYH2R2V5
